{
  "name": "howtocook-app",
  "version": "1.0.0",
  "private": true,
  "description": "爱学做菜 - 家常菜谱与烹饪知识指南",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "check": "npm run typecheck && npm run lint && npm run build:weapp"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "author": "",
  "license": "Unlicense",
  "dependencies": {
    "@babel/runtime": "^7.21.0",
    "@tarojs/components": "3.6.23",
    "@tarojs/helper": "3.6.23",
    "@tarojs/plugin-framework-react": "3.6.23",
    "@tarojs/plugin-html": "3.6.23",
    "@tarojs/react": "3.6.23",
    "@tarojs/runtime": "3.6.23",
    "@tarojs/shared": "3.6.23",
    "@tarojs/taro": "3.6.23",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.21.0",
    "@babel/preset-react": "^7.18.6",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.10",
    "@tarojs/cli": "3.6.23",
    "@tarojs/plugin-platform-h5": "3.6.23",
    "@tarojs/plugin-platform-weapp": "3.6.23",
    "@tarojs/taro-loader": "3.6.23",
    "@tarojs/webpack5-runner": "3.6.23",
    "@types/react": "^18.2.0",
    "@types/webpack-env": "^1.18.0",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "babel-preset-taro": "3.6.23",
    "eslint": "^8.40.0",
    "eslint-config-taro": "3.6.23",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.23",
    "react-refresh": "^0.14.0",
    "sass": "^1.62.1",
    "stylelint": "^15.6.0",
    "typescript": "5.9.3",
    "webpack": "5.102.1"
  }
}
